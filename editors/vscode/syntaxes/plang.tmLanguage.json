{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "PLang",
  "scopeName": "source.plang",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#chars" },
    { "include": "#numbers" },
    { "include": "#module-decl" },
    { "include": "#use-decl" },
    { "include": "#extern-decl" },
    { "include": "#function-def" },
    { "include": "#type-def" },
    { "include": "#trait-impl" },
    { "include": "#test-decl" },
    { "include": "#keywords" },
    { "include": "#constants" },
    { "include": "#operators" },
    { "include": "#types" },
    { "include": "#function-call" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.plang",
          "match": "//.*$"
        }
      ]
    },

    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.plang",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.plang",
              "match": "\\\\(?:[\\\\\"nrt0]|x[0-9a-fA-F]{2}|u\\{[0-9a-fA-F]+\\})"
            }
          ]
        }
      ]
    },

    "chars": {
      "patterns": [
        {
          "name": "string.quoted.single.plang",
          "match": "'(?:[^'\\\\]|\\\\(?:[\\\\'nrt0]|x[0-9a-fA-F]{2}|u\\{[0-9a-fA-F]+\\}))'"
        }
      ]
    },

    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.plang",
          "match": "\\b[0-9][0-9_]*\\.[0-9][0-9_]*(?:[eE][+-]?[0-9]+)?\\b"
        },
        {
          "name": "constant.numeric.hex.plang",
          "match": "\\b0x[0-9a-fA-F_]+\\b"
        },
        {
          "name": "constant.numeric.binary.plang",
          "match": "\\b0b[01_]+\\b"
        },
        {
          "name": "constant.numeric.integer.plang",
          "match": "\\b[0-9][0-9_]*\\b"
        }
      ]
    },

    "module-decl": {
      "patterns": [
        {
          "match": "\\b(module)\\s+([a-zA-Z_][a-zA-Z0-9_.]*)",
          "captures": {
            "1": { "name": "keyword.other.module.plang" },
            "2": { "name": "entity.name.namespace.plang" }
          }
        }
      ]
    },

    "use-decl": {
      "patterns": [
        {
          "match": "\\b(use)\\s+([a-zA-Z_][a-zA-Z0-9_.]*)",
          "captures": {
            "1": { "name": "keyword.control.import.plang" },
            "2": { "name": "entity.name.namespace.plang" }
          }
        }
      ]
    },

    "extern-decl": {
      "patterns": [
        {
          "match": "\\b(extern)\\s+(module)\\s+\"([^\"]+)\"(?:\\s+(as)\\s+([a-zA-Z_][a-zA-Z0-9_]*))?",
          "captures": {
            "1": { "name": "keyword.other.extern.plang" },
            "2": { "name": "keyword.other.module.plang" },
            "3": { "name": "string.quoted.double.plang" },
            "4": { "name": "keyword.other.as.plang" },
            "5": { "name": "entity.name.namespace.plang" }
          }
        },
        {
          "match": "\\b(extern)\\s+(?:(async)\\s+)?(fn)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.other.extern.plang" },
            "2": { "name": "storage.modifier.async.plang" },
            "3": { "name": "keyword.other.fn.plang" },
            "4": { "name": "entity.name.function.plang" }
          }
        }
      ]
    },

    "function-def": {
      "patterns": [
        {
          "match": "\\b(?:(pub)\\s+)?(?:(async)\\s+)?(fn)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "storage.modifier.visibility.plang" },
            "2": { "name": "storage.modifier.async.plang" },
            "3": { "name": "keyword.other.fn.plang" },
            "4": { "name": "entity.name.function.plang" }
          }
        }
      ]
    },

    "type-def": {
      "patterns": [
        {
          "match": "\\b(?:(pub)\\s+)?(type)\\s+([A-Z][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "storage.modifier.visibility.plang" },
            "2": { "name": "keyword.other.type.plang" },
            "3": { "name": "entity.name.type.plang" }
          }
        }
      ]
    },

    "trait-impl": {
      "patterns": [
        {
          "match": "\\b(?:(pub)\\s+)?(trait)\\s+([A-Z][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "storage.modifier.visibility.plang" },
            "2": { "name": "keyword.other.trait.plang" },
            "3": { "name": "entity.name.type.plang" }
          }
        },
        {
          "match": "\\b(impl)\\s+([A-Z][a-zA-Z0-9_]*)(?:\\s+(for)\\s+([A-Z][a-zA-Z0-9_]*))?",
          "captures": {
            "1": { "name": "keyword.other.impl.plang" },
            "2": { "name": "entity.name.type.plang" },
            "3": { "name": "keyword.other.for.plang" },
            "4": { "name": "entity.name.type.plang" }
          }
        }
      ]
    },

    "test-decl": {
      "patterns": [
        {
          "match": "\\b(test)\\s+\"([^\"]+)\"",
          "captures": {
            "1": { "name": "keyword.other.test.plang" },
            "2": { "name": "string.quoted.double.plang" }
          }
        }
      ]
    },

    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.plang",
          "match": "\\b(if|else|match|for|in|while|return|break|continue|await|select|timeout)\\b"
        },
        {
          "name": "keyword.other.plang",
          "match": "\\b(let|var|fn|type|trait|impl|module|use|pub|extern|as|with|test)\\b"
        },
        {
          "name": "storage.modifier.plang",
          "match": "\\b(async|pub)\\b"
        },
        {
          "name": "keyword.operator.plang",
          "match": "\\b(require|ensure|assert)\\b"
        },
        {
          "name": "keyword.channel.plang",
          "match": "\\b(channel|send|recv|spawn|task_group|catch)\\b"
        }
      ]
    },

    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.plang",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.null.plang",
          "match": "\\b(null)\\b"
        },
        {
          "name": "constant.language.option.plang",
          "match": "\\b(None)\\b"
        },
        {
          "name": "variable.language.self.plang",
          "match": "\\b(self)\\b"
        },
        {
          "name": "support.function.builtin.plang",
          "match": "\\b(Some|Ok|Err|println|to_option)\\b"
        }
      ]
    },

    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.plang",
          "match": "==|!=|<=|>=|<|>|~="
        },
        {
          "name": "keyword.operator.logical.plang",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.arithmetic.plang",
          "match": "\\+\\+|\\+|-|\\*|/|%"
        },
        {
          "name": "keyword.operator.pipe.plang",
          "match": "\\|>"
        },
        {
          "name": "keyword.operator.range.plang",
          "match": "\\.\\."
        },
        {
          "name": "keyword.operator.arrow.plang",
          "match": "->"
        },
        {
          "name": "keyword.operator.fat-arrow.plang",
          "match": "=>"
        },
        {
          "name": "keyword.operator.propagate.plang",
          "match": "\\?"
        }
      ]
    },

    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.plang",
          "match": "\\b(Int|Float|Bool|Char|Str|Void|Any)\\b"
        },
        {
          "name": "support.type.generic.plang",
          "match": "\\b(Option|Result|List|Map|Channel)\\b"
        },
        {
          "name": "entity.name.type.plang",
          "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
        }
      ]
    },

    "function-call": {
      "patterns": [
        {
          "match": "\\b([a-z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.call.plang" }
          }
        }
      ]
    },

    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.plang",
          "match": "\\b[a-z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
